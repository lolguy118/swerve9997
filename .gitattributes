# Enforce LF line endings for all text files (CODE-FMT-005)
* text=auto eol=lf

# Ensure these are always treated as text
*.java text eol=lf
*.gradle text eol=lf
*.md text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.gif binary
